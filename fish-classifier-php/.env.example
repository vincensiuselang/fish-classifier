# ============================================================
# CONTOH ENVIRONMENT VARIABLE
# ============================================================
# LOKAL (XAMPP): TIDAK PERLU set apa-apa. Default sudah:
#   host=127.0.0.1 user=root pass=(kosong) db=fish_classifier
#
# RAILWAY: tambah 1 service database "MySQL", lalu di service APP
# set variable berikut (Railway -> Variables -> New Variable):
#
#   DATABASE_URL = ${{MySQL.MYSQL_URL}}
#
# (nilai ${{MySQL.MYSQL_URL}} otomatis nyambung ke service MySQL kamu)
#
# Opsional - resolusi inference (128 cepat / 160 seimbang / 224 akurat):
#   FISH_IMG_SIZE = 128
# ============================================================

DATABASE_URL=mysql://root:password@localhost:3306/fish_classifier
FISH_IMG_SIZE=128
